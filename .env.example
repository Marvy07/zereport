# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Clerk redirect URLs (legacy env vars — pre-v5 fallback)
# Prefer afterSignInUrl / afterSignUpUrl props on <ClerkProvider> for Clerk v5+
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=
DIRECT_URL=

# Stripe
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_STARTER_PRICE_ID=
STRIPE_PRO_PRICE_ID=
STRIPE_AGENCY_PRICE_ID=

# Resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=reports@zereport.io
RESEND_FROM_NAME=Zereport

# Supabase Storage
SUPABASE_STORAGE_BUCKET_ASSETS=workspace-assets
SUPABASE_STORAGE_BUCKET_REPORTS=generated-reports

# Integrations OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
TRELLO_API_KEY=
TRELLO_API_SECRET=
GHL_CLIENT_ID=
GHL_CLIENT_SECRET=

# Rate Limiting
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Admin
# Admin bootstrap — comma-separated Clerk user IDs that get isPlatformAdmin=true on first sign-in
# e.g. ADMIN_USER_IDS=user_abc123,user_def456
ADMIN_USER_IDS=

# App
NEXT_PUBLIC_APP_URL=https://zereport.io
NEXT_PUBLIC_APP_NAME=Zereport
NODE_ENV=development

# Vercel Cron Protection
CRON_SECRET=
